# Calculate mean normalized counts per compartment
ternary_df <- data.frame(
miRNA = rownames(norm_counts),
Exo = rowMeans(norm_counts[, exo_samples, drop = FALSE]),
Ti  = rowMeans(norm_counts[, ti_samples, drop = FALSE]),
CF  = rowMeans(norm_counts[, cf_samples, drop = FALSE])
)
# Remove miRNAs with zero everywhere
ternary_df <- ternary_df[rowSums(ternary_df[,2:4]) > 0, ]
ternary_df <- ternary_df %>%
rowwise() %>%
mutate(
total = Exo + Ti + CF,
Exo_p = Exo / total,
Ti_p  = Ti  / total,
CF_p  = CF  / total
) %>%
ungroup()
ternary_df <- ternary_df[ternary_df$total > 50, ]
ternary_df$Dominant <- apply(
ternary_df[, c("Exo","Ti","CF")],
1,
function(x) c("Exo","Ti","CF")[which.max(x)]
)
p_ternary <- ggtern(
ternary_df,
aes(x = Exo_p, y = CF_p, z = Ti_p, color = Dominant)
) +
geom_point(alpha = 0.7, size = 2) +
theme_bw(base_size = 14) +
labs(
title = "Ternary Plot of miRNA Distribution Across Compartments",
T = "Exosome",
L = "Cell-Free",
R = "Tissue"
) +
scale_color_manual(values = c(
"Exo" = "#b22222",
"Ti"  = "#2e8b57",
"CF"  = "#1f4e79"
)) +
theme(
plot.title = element_text(hjust = 0.5, face = "bold")
)
print(p_ternary)
ggsave(
"figures/ternary_miRNA_distribution.png",
p_ternary,
width = 7,
height = 6,
dpi = 300
)
