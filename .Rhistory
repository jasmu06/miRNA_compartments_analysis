# --- Load all required libraries at the top ---
library(DESeq2)
library(ggplot2)
library(pheatmap)
library(dplyr)
library(tidyr)
library(ggpubr)
library(RColorBrewer)
library(ggrepel)
install.packages("VennDiagram")
library(VennDiagram)
library(cowplot)
# -------------------------------
# Step 1: Load counts and metadata
# -------------------------------
counts <- read.csv("data/processed/miRNA_count_matrix.csv",
row.names = 1,
check.names = FALSE,
stringsAsFactors = FALSE)
metadata <- read.csv("data/processed/metadata_mirna.csv",
row.names = 1,
check.names = FALSE,
stringsAsFactors = FALSE)
# Optional: keep only Compartment column
metadata <- metadata[, "Compartment", drop = FALSE]
# -------------------------------
# Step 2: Convert counts to numeric
# -------------------------------
counts[] <- lapply(counts, function(x) as.numeric(as.character(x)))
counts_mat <- as.matrix(counts)
# Replace any NA with 0
counts_mat[is.na(counts_mat)] <- 0
# -------------------------------
# Step 3: Reorder metadata to match counts
# -------------------------------
metadata <- metadata[colnames(counts_mat), , drop = FALSE]
# -------------------------------
# Step 4: Create DESeq2 dataset
# -------------------------------
dds <- DESeqDataSetFromMatrix(
countData = counts_mat,
colData = metadata,
design = ~ Compartment
)
# Remove miRNAs with all zeros
dds <- dds[rowSums(counts(dds)) > 0, ]
# -------------------------------
# Step 5: Estimate size factors using poscounts
# -------------------------------
dds <- estimateSizeFactors(dds, type = "poscounts")
# -------------------------------
# Step 6: Run DESeq2 differential expression
# -------------------------------
dds <- DESeq(dds, sfType = "poscounts")
# Check compartment levels
levels(colData(dds)$Compartment)
# Calculate mean normalized counts per compartment
ternary_df <- data.frame(
miRNA = rownames(norm_counts),
Exo = rowMeans(norm_counts[, exo_samples, drop = FALSE]),
Ti  = rowMeans(norm_counts[, ti_samples, drop = FALSE]),
CF  = rowMeans(norm_counts[, cf_samples, drop = FALSE])
)
# Remove miRNAs with zero everywhere
ternary_df <- ternary_df[rowSums(ternary_df[,2:4]) > 0, ]
# ---- Ternary Plot Section ----
install.packages("ggtern")
library(ggtern)
# Calculate mean normalized counts per compartment
ternary_df <- data.frame(
miRNA = rownames(norm_counts),
Exo = rowMeans(norm_counts[, exo_samples, drop = FALSE]),
Ti  = rowMeans(norm_counts[, ti_samples, drop = FALSE]),
CF  = rowMeans(norm_counts[, cf_samples, drop = FALSE])
)
ls()
dds
# Calculate mean normalized counts per compartment
ternary_df <- data.frame(
miRNA = rownames(norm_counts),
Exo = rowMeans(norm_counts[, exo_samples, drop = FALSE]),
Ti  = rowMeans(norm_counts[, ti_samples, drop = FALSE]),
CF  = rowMeans(norm_counts[, cf_samples, drop = FALSE])
)
# -------------------------------
# Step 6: Run DESeq2 differential expression
# -------------------------------
dds <- DESeq(dds, sfType = "poscounts")
# Check compartment levels
levels(colData(dds)$Compartment)
ls()
norm_counts <- counts(dds, normalized = TRUE)
ls()
# Calculate mean normalized counts per compartment
ternary_df <- data.frame(
miRNA = rownames(norm_counts),
Exo = rowMeans(norm_counts[, exo_samples, drop = FALSE]),
Ti  = rowMeans(norm_counts[, ti_samples, drop = FALSE]),
CF  = rowMeans(norm_counts[, cf_samples, drop = FALSE])
)
# --- Step 6a: Pairwise comparisons ---
res_exo_vs_cf <- results(dds, contrast = c("Compartment", "exo", "cf"))
res_exo_vs_ti <- results(dds, contrast = c("Compartment", "exo", "ti"))
res_ti_vs_cf  <- results(dds, contrast = c("Compartment", "ti", "cf"))
# Summaries
summary(res_exo_vs_cf)
summary(res_exo_vs_ti)
summary(res_ti_vs_cf)
# -------------------------------
# Step 7: Extract significant miRNAs (FDR < 0.05)
# -------------------------------
sig_exo_vs_cf <- res_exo_vs_cf[which(res_exo_vs_cf$padj < 0.05), ]
sig_exo_vs_cf <- sig_exo_vs_cf[order(sig_exo_vs_cf$padj), ]
sig_exo_vs_ti <- res_exo_vs_ti[which(res_exo_vs_ti$padj < 0.05), ]
sig_exo_vs_ti <- sig_exo_vs_ti[order(sig_exo_vs_ti$padj), ]
sig_ti_vs_cf <- res_ti_vs_cf[which(res_ti_vs_cf$padj < 0.05), ]
sig_ti_vs_cf <- sig_ti_vs_cf[order(sig_ti_vs_cf$padj), ]
# Save significant miRNAs
write.csv(as.data.frame(sig_exo_vs_cf), "results/sig_miRNAs_exo_vs_cf.csv", row.names = TRUE)
# -------------------------------
# Step 9: Variance stabilizing transformation and PCA
# -------------------------------
vsd <- varianceStabilizingTransformation(dds, blind = FALSE)
vsd_mat <- assay(vsd)
# Calculate mean normalized counts per compartment
